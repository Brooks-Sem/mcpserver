{
  "mcpServers": {
    "codex": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/Brooks-Sem/mcpserver.git@v0.1.0", "mcp-codex"]
    },
    "claude": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/Brooks-Sem/mcpserver.git@v0.1.0", "mcp-claude"]
    },
    "grok": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/Brooks-Sem/mcpserver.git@v0.1.0", "mcp-grok"],
      "env": {
        "GROK_API_URL": "SET_LOCALLY",
        "GROK_API_KEY": "SET_LOCALLY",
        "GROK_MODEL": "grok-4",
        "GROK_REASONING_EFFORT": "high",
        "GROK_REASONING_FIELD": "reasoning_effort"
      }
    }
  }
}
