# Grok uses an OpenAI-compatible API. Never commit real values.
GROK_API_URL=https://api.x.ai/v1
GROK_API_KEY=replace-locally
GROK_MODEL=grok-4
GROK_REASONING_EFFORT=high
GROK_REASONING_FIELD=reasoning_effort
GROK_TIMEOUT_SECONDS=180
GROK_MAX_RETRIES=3

# Optional override for local CLI discovery.
# CODEX_COMMAND=codex.cmd
# CLAUDE_COMMAND=claude.cmd

# Claude/Codex have no total runtime limit. They stop only after this many
# consecutive seconds without stdout or stderr output.
MODEL_MCP_CLI_IDLE_TIMEOUT_SECONDS=300
